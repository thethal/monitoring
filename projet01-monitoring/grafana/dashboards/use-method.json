{
  "uid": "use-method-eservice",
  "title": "USE Method — Infrastructure Linux (E-Service)",
  "tags": [
    "use",
    "infrastructure",
    "node-exporter",
    "eservice"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "Environnement",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(node_uname_info, environment)",
        "query": {
          "query": "label_values(node_uname_info, environment)",
          "refId": "environment"
        },
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": true,
        "current": {},
        "hide": 0
      },
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(up, job)",
        "query": {
          "query": "label_values(up, job)",
          "refId": "job"
        },
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": true,
        "current": {},
        "hide": 0
      },
      {
        "name": "instance",
        "label": "Instance (serveur)",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(node_uname_info{environment=\"$environment\"}, hostname)",
        "query": {
          "query": "label_values(node_uname_info{environment=\"$environment\"}, hostname)",
          "refId": "instance"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "current": {},
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "type": "dashboard",
        "name": "Annotations & Alerts",
        "enable": true,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "iconColor": "rgba(0, 211, 255, 1)"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "## Méthode **USE** — Utilization · Saturation · Errors\nSource : *Node Exporter*. Sélectionnez l'environnement et le(s) serveur(s) via les menus en haut."
      }
    },
    {
      "id": 2,
      "type": "row",
      "title": "Utilization — Taux d'utilisation des ressources",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "panels": []
    },
    {
      "id": 10,
      "type": "gauge",
      "title": "CPU — Utilisation (%)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "100 - (avg by (hostname) (rate(node_cpu_seconds_total{hostname=~\"$instance\", mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{hostname}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "id": 11,
      "type": "gauge",
      "title": "Mémoire — Utilisation (%)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "(1 - (node_memory_MemAvailable_bytes{hostname=~\"$instance\"} / node_memory_MemTotal_bytes{hostname=~\"$instance\"})) * 100",
          "legendFormat": "{{hostname}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
