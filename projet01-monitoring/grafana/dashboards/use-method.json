          "expr": "(1 - (node_filesystem_avail_bytes{hostname=~\"$instance\", mountpoint=\"/\"} / node_filesystem_size_bytes{hostname=~\"$instance\", mountpoint=\"/\"})) * 100",
          "legendFormat": "{{hostname}}",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
